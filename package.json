{
  "name": "@neumie/pi-tool-display-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Private Neumie bridge that loads the maintained pi-tool-display fork and Hypa through one Pi extension API.",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@hypabolic/pi-hypa": "0.1.11",
    "pi-tool-display": "git+https://github.com/neumie/pi-tool-display.git#347c342bf61c0bc8867f02aa2a50cc020e3ca45f"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@earendil-works/pi-tui": "^0.80.10",
    "@types/node": "^24.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "brace-expansion": "5.0.7",
    "protobufjs": "7.6.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neumie/pi-tool-display-bridge.git"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "index.ts",
    "README.md"
  ]
}
